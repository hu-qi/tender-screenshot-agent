{
  "name": "@tender/agent-host",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.19.0"
  },
  "scripts": {
    "dev": "npm run build && node --watch dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node --test test/*.test.mjs",
    "local:config": "npm run build && node dist/security-cli.js",
    "explore:qwebbridge": "npm run build && node dist/explore-cli.js"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "0.80.3",
    "@earendil-works/pi-ai": "0.80.3",
    "@wecom/aibot-node-sdk": "1.0.6",
    "playwright": "1.46.0",
    "typebox": "1.1.38"
  },
  "devDependencies": {
    "@types/node": "24.12.4",
    "typescript": "5.9.3"
  }
}
