# 标讯截图助手：本地开发环境变量示例
#
# 用法：cp .env.example .env
#
# .env 只能放本机运行参数，绝不能放 API Key、企业微信 Webhook、账号密码、Cookie、
# 浏览器 Profile、SMTP 密码、CA/UKey 或任何生产凭证。上述敏感信息必须进入 OS Keychain。

# 可选：指定 Playwright 使用的本机 Chromium / Chrome 可执行文件。
# 留空时 Playwright 使用自身已安装的 Chromium。
TENDER_PLAYWRIGHT_CHROMIUM_PATH=

# 可选：Sidecar 的运行日志级别。当前支持 error / warn / info / debug。
TENDER_SIDECAR_LOG_LEVEL=info

# 可选：桌面端本地日志级别。当前支持 error / warn / info / debug。
TENDER_APP_LOG_LEVEL=info

# 可选：开发期证据输出根目录。留空时使用应用数据目录。
TENDER_DATA_DIR=

# 可选：开发期 Sidecar 启动超时（毫秒）。
TENDER_SIDECAR_STARTUP_TIMEOUT_MS=15000

# Provider 配置不在 .env 中保存 Token。
# 请复制 config/providers.example.json 为本机 config/providers.json，
# 并把 credentialRef 指向系统密钥链中的凭证引用。
