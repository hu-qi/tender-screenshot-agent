# 标讯截图助手 / 本地配置模板
#
# 首次使用：npm run local:config:init
# 编辑 .env 后：npm run local:config:apply
# 自检：npm run local:config:doctor
# 模型连通性测试：npm run local:config -- test-model --confirm-model-egress
#
# .env 已被 Git 忽略。local:config:init / apply 会将权限收紧为 0600。
# 不要把 .env、Profile、Cookie、截图、Trace、SQLite、CA/UKey 文件或受限附件提交到 Git。

# 强制 .env 仅允许当前用户读取。建议保持 true。
TENDER_SECURITY_ENFORCE_ENV_PERMISSIONS=true

# 可选：本机 Chromium / Google Chrome 可执行路径。
# 留空时使用 Playwright 已安装的 Chromium。
TENDER_PLAYWRIGHT_CHROMIUM_PATH=

# 可选：Host 数据、配置和平台 registry 位置。
TENDER_DATA_DIR=
TENDER_CONFIG_DIR=
TENDER_PLATFORM_CONFIG=

# 浏览器导航超时（毫秒）。
TENDER_BROWSER_TIMEOUT_MS=45000

# QWebBridge Explorer：只允许本机 loopback 地址。
# Explorer 默认只做 snapshot、截图和固定脱敏 DOM 分析；搜索 probe 仍需显式命令授权。
TENDER_QWEBBRIDGE_ENABLED=false
TENDER_QWEBBRIDGE_URL=http://127.0.0.1:10086

# 企业微信智能机器人。
# local:config:apply 会将 Bot ID / Bot Secret 写入 macOS Keychain；
# SQLite 仅保存 enabled、目标会话数量和可选 WebSocket 地址，不保存密钥。
TENDER_WECOM_ENABLED=false
TENDER_WECOM_BOT_ID=
TENDER_WECOM_BOT_SECRET=
# 多个目标使用逗号或分号分隔；例如 chatid-1,userid-1
TENDER_WECOM_TARGET_IDS=
# 留空则使用 SDK 默认 WebSocket 地址。
TENDER_WECOM_WEBSOCKET_URL=

# Pi 模型 Profile。默认禁用，采集始终保留确定性 query × platform 基线。
# 启用 orchestrate 后，模型仅接收 query/platform 元数据与工具摘要；不会收到原始证据、HTML、截图、PDF、Cookie 或本地路径。
TENDER_LLM_ENABLED=false
TENDER_LLM_MODE=disabled
TENDER_LLM_PROFILE=default

# builtin：Pi 已知外部 Provider，必须显式选择 external-approved。
# openai-compatible：公司内网网关、vLLM、Ollama 或其他 OpenAI-compatible endpoint。
TENDER_LLM_PROVIDER_KIND=builtin
TENDER_LLM_PROVIDER=
TENDER_LLM_MODEL=

# keychain：API Key 由 apply 写入 macOS Keychain；none：仅用于无需认证的本机 endpoint。
TENDER_LLM_AUTH_MODE=keychain
TENDER_LLM_API_KEY=

# 模型数据与出网边界。
# metadata-only 是默认且推荐的策略；redacted-text 仍不传原始证据文件。
TENDER_LLM_DATA_POLICY=metadata-only
# builtin 必须设 external-approved；openai-compatible 可选 local-only / internal-only / external-approved。
TENDER_LLM_EGRESS_POLICY=local-only
# 仅 openai-compatible 使用。builtin 必须留空。
TENDER_LLM_BASE_URL=
# internal-only 时必须列出 endpoint hostname；逗号或分号分隔。
TENDER_LLM_ALLOWED_HOSTS=

# 防止模型编排失控的每运行限制。
TENDER_LLM_MAX_REQUESTS_PER_RUN=6
TENDER_LLM_MAX_INPUT_CHARS=12000
TENDER_LLM_MAX_OUTPUT_TOKENS=1200
TENDER_LLM_CONTEXT_WINDOW=32768

# 仅在直接启动 Agent Host 时需要：本机端口与 bearer token。
# Tauri 桌面端会自动传入随机端口和每次启动独立 token。
# TENDER_AGENT_PORT=39177
# TENDER_AGENT_TOKEN=

# 可选：桌面壳调试时覆盖 Host 启动方式。
# TENDER_NODE_BIN=/opt/homebrew/bin/node
# TENDER_AGENT_HOST_SCRIPT=/absolute/path/to/packages/agent-host/dist/index.js
# TENDER_AGENT_HOST_BIN=/absolute/path/to/packaged-agent-host
