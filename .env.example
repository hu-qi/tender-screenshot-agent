# 标讯截图助手 / 本地配置模板
#
# 首次使用：npm run local:config:init
# 编辑 .env 后：npm run local:config:apply
# 自检：npm run local:config:doctor
#
# .env 已被 Git 忽略。local:config:init / apply 会将权限收紧为 0600。
# 不要把 .env、Profile、Cookie、截图、Trace、SQLite、CA/UKey 文件或受限附件提交到 Git。

# 强制 .env 仅允许当前用户读取。建议保持 true。
TENDER_SECURITY_ENFORCE_ENV_PERMISSIONS=true

# 可选：本机 Chromium / Google Chrome 可执行路径。
# 留空时使用 Playwright 已安装的 Chromium。
TENDER_PLAYWRIGHT_CHROMIUM_PATH=

# 可选：Host 数据、配置和平台 registry 位置。
TENDER_DATA_DIR=
TENDER_CONFIG_DIR=
TENDER_PLATFORM_CONFIG=

# 浏览器导航超时（毫秒）。
TENDER_BROWSER_TIMEOUT_MS=45000

# QWebBridge Explorer：只允许本机 loopback 地址。
# Explorer 默认只做 snapshot、截图和固定脱敏 DOM 分析；搜索 probe 仍需显式命令授权。
TENDER_QWEBBRIDGE_ENABLED=false
TENDER_QWEBBRIDGE_URL=http://127.0.0.1:10086

# 企业微信智能机器人。
# local:config:apply 会将 Bot ID / Bot Secret 写入 macOS Keychain；
# SQLite 仅保存 enabled、目标会话数量和可选 WebSocket 地址，不保存密钥。
# 值只需维护在此 .env，命令输出绝不会回显 Bot ID 或 Secret。
TENDER_WECOM_ENABLED=false
TENDER_WECOM_BOT_ID=
TENDER_WECOM_BOT_SECRET=
# 多个目标可用逗号、分号或换行分隔；例如 chatid-1,userid-1
TENDER_WECOM_TARGET_IDS=
# 留空则使用 SDK 默认 WebSocket 地址。
TENDER_WECOM_WEBSOCKET_URL=

# 仅在直接启动 Agent Host 时需要：本机端口与 bearer token。
# Tauri 桌面端会自动传入随机端口和每次启动独立 token。
# TENDER_AGENT_PORT=39177
# TENDER_AGENT_TOKEN=

# 可选：启用 Pi LLM 编排。未配置时使用确定性 query × platform 执行。
# Provider 凭证由 Pi provider 或系统凭证适配器管理，不放入 .env。
# TENDER_LLM_PROVIDER=
# TENDER_LLM_MODEL=

# 可选：桌面壳调试时覆盖 Host 启动方式。
# TENDER_NODE_BIN=/opt/homebrew/bin/node
# TENDER_AGENT_HOST_SCRIPT=/absolute/path/to/packages/agent-host/dist/index.js
# TENDER_AGENT_HOST_BIN=/absolute/path/to/packaged-agent-host
